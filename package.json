{
  "name": "choir",
  "displayName": "Choir",
  "description": "Workspace-aware strategy and knowledge layer for your project",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:choir.analyst",
    "onChatParticipant:choir.architect",
    "onChatParticipant:choir.enforcer",
    "onChatParticipant:choir.conductor"
  ],
  "main": "./out/vscode/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "choir.openRuleEditor",
        "title": "Choir: Open Rule Editor",
        "category": "Choir"
      },
      {
        "command": "choir.revealRuleEditorDebug",
        "title": "Choir: Debug Reveal Rule Editor",
        "category": "Choir"
      },
      {
        "command": "choir.openRuleEditorPanel",
        "title": "Choir: Open Rule Editor (Panel)",
        "category": "Choir"
      },
      {
        "command": "choir.openRuleEditorPanelResolve",
        "title": "Choir: Open Rule Editor (Panel Resolve)",
        "category": "Choir"
      },
      {
        "command": "choir.showDslEditorTrace",
        "title": "Choir: Show DSL Editor Trace",
        "category": "Choir"
      }
    ],
    "languages": [
      {
        "id": "choir",
        "extensions": [
          ".choir"
        ],
        "aliases": [
          "Choir DSL",
          "choir"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "choir",
        "scopeName": "source.choir",
        "path": "./syntaxes/choir.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "choir",
        "path": "./snippets/choir.json"
      }
    ],
    "configurationDefaults": {
      "files.associations": {
        "*.choir": "choir"
      }
    },
    "chatParticipants": [
      {
        "id": "choir.analyst",
        "name": "Choir-Analyst",
        "fullName": "Choir Analyst",
        "description": "Analyzes the project structure and provides insights to the choir.",
        "isSticky": true
      },
      {
        "id": "choir.architect",
        "name": "Choir-Architect",
        "fullName": "Choir Architect",
        "description": "Designs the overall architecture and strategy for the project.",
        "isSticky": true
      },
      {
        "id": "choir.enforcer",
        "name": "Choir-Enforcer",
        "fullName": "Choir Enforcer",
        "description": "Ensures that the project adheres to the defined strategy and architecture.",
        "isSticky": true
      },
      {
        "id": "choir.conductor",
        "name": "Choir-Conductor",
        "fullName": "Choir Conductor",
        "description": "Builds deterministic plans and coordinates dependency-aware task execution through existing Choir agents.",
        "isSticky": true
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "choir",
          "title": "Choir",
          "icon": "media/choir.png"
        }
      ]
    },
    "views": {
      "choir": [
        {
          "id": "choir.ruleList",
          "name": "Rules",
          "icon": "media/choir.png"
        },
        {
          "type": "webview",
          "id": "choir.ruleEditor",
          "name": "Rule Editor",
          "icon": "media/choir.png"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "tsc -p ./",
    "build:webview": "vite build",
    "watch": "npm run watch:extension",
    "watch:extension": "tsc -watch -p ./",
    "watch:webview": "vite build --watch",
    "dev:webview": "vite",
    "test:rules": "npm run build:extension && node out/tests/rules/harness.js",
    "test:architecture": "npm run build:extension && node out/tests/architecture/suite.js",
    "test": "npm run test:rules && npm run test:architecture"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.90.0",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "monaco-editor": "^0.53.0",
    "monaco-yaml": "^5.4.1",
    "ts-morph": "^28.0.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.2"
  }
}
