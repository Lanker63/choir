{
  "name": "choir",
  "displayName": "Choir",
  "description": "Workspace-aware strategy and knowledge layer for your project",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:choir"
  ],
  "main": "./out/vscode/extension.js",
  "bin": {
    "choir": "./out/cli.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "choir.openRuleEditor",
        "title": "Choir: Open Control Center",
        "category": "Choir",
        "icon": "$(dashboard)"
      },
      {
        "command": "choir.revealRuleEditorDebug",
        "title": "Choir: Debug Reveal Rule Editor",
        "category": "Choir"
      },
      {
        "command": "choir.openRuleEditorPanel",
        "title": "Choir: Open Control Center (Panel)",
        "category": "Choir"
      },
      {
        "command": "choir.openRuleEditorPanelResolve",
        "title": "Choir: Open Control Center (Panel Resolve)",
        "category": "Choir"
      },
      {
        "command": "choir.showDslEditorTrace",
        "title": "Choir: Show DSL Editor Trace",
        "category": "Choir"
      },
      {
        "command": "choir.openDependencyGraph",
        "title": "Choir: Open Dependency Graph",
        "category": "Choir",
        "icon": "$(graph)"
      },
      {
        "command": "choir.openTimeline",
        "title": "Choir: Open Timeline",
        "category": "Choir",
        "icon": "$(history)"
      },
      {
        "command": "choir.graph.setMode",
        "title": "Choir: Set Graph Mode",
        "category": "Choir"
      },
      {
        "command": "choir.showWebviewSyncTrace",
        "title": "Choir: Show Webview Sync Trace",
        "category": "Choir"
      }
    ],
    "languages": [
      {
        "id": "choir",
        "extensions": [
          ".choir"
        ],
        "aliases": [
          "Choir DSL",
          "choir"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "choir",
        "scopeName": "source.choir",
        "path": "./syntaxes/choir.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "choir",
        "path": "./snippets/choir.json"
      }
    ],
    "configurationDefaults": {
      "files.associations": {
        "*.choir": "choir"
      }
    },
    "chatParticipants": [
      {
        "id": "choir",
        "fullName": "Choir",
        "name": "choir",
        "description": "Unified orchestration agent for intent, planning, and enforcement",
        "isSticky": true
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "choir",
          "title": "Choir",
          "icon": "media/choir.png"
        }
      ]
    },
    "views": {
      "choir": [
        {
          "id": "choir.ruleList",
          "name": "Rules",
          "icon": "media/choir.png"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "choir.openRuleEditor",
          "when": "view == choir.ruleList",
          "group": "navigation@1"
        },
        {
          "command": "choir.openDependencyGraph",
          "when": "view == choir.ruleList",
          "group": "navigation@2"
        },
        {
          "command": "choir.openTimeline",
          "when": "view == choir.ruleList",
          "group": "navigation@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run clean:tmp && npm run build:extension && npm run build:webview",
    "clean:tmp": "find . -name '.tmp-*' -exec rm -rf {} +",
    "build:extension": "tsc -p ./",
    "build:webview": "vite build",
    "watch": "npm run watch:extension",
    "watch:extension": "tsc -watch -p ./",
    "watch:webview": "vite build --watch",
    "dev:webview": "vite",
    "ci:run": "node out/cli.js ci run",
    "test:rules": "npm run build:extension && node out/tests/rules/harness.js",
    "test:architecture": "npm run build:extension && node out/tests/architecture/suite.js",
    "test": "npm run test:rules && npm run test:architecture"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.90.0",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "glob": "^13.0.6",
    "monaco-editor": "^0.53.0",
    "monaco-yaml": "^5.4.1",
    "ts-morph": "^28.0.0",
    "yaml": "^2.8.4",
    "zod": "^4.4.2"
  }
}
